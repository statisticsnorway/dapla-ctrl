{
	"name": "console-frontend",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.7.0",
	"scripts": {
		"prepare": "cd .. && husky frontend/.husky && cd frontend && svelte-kit sync || echo ''",
		"dev": "vite dev",
		"dev-live-share": "vite dev --host ::",
		"build": "vite build",
		"preview": "vite preview",
		"check": "pnpm dlx houdini generate && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"eslint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest",
		"lint-staged": "lint-staged",
		"unused": "node find-unused-gql.mjs && echo '---' && node find-missing-css-vars.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@nais/ds-svelte-community": "2.0.0-next.8",
		"@navikt/ds-css": "8.9.1",
		"@navikt/ds-tokens": "8.9.1",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "2.68.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/papaparse": "^5.5.2",
		"@types/sortablejs": "^1.15.9",
		"date-fns": "^4.4.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"eslint-plugin-unicorn": "^68.0.0",
		"globals": "^17.7.0",
		"houdini": "2.0.0-next.11",
		"houdini-svelte": "3.0.0-next.13",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "5.55.4",
		"svelte-check": "4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0",
		"vite": "8.1.0",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"dependencies": {
		"graphql": "^16.14.2",
		"graphql-sse": "^2.6.0",
		"papaparse": "^5.5.4",
		"pino": "^10.3.1",
		"sortablejs": "^1.15.7"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.0"
		}
	},
	"lint-staged": {
		"*.{js,ts,svelte,gql,css,md,json}": "prettier --write .",
		"*.{js,ts,svelte,gql}": [
			"eslint --fix .",
			"svelte-check --tsconfig ./tsconfig.json --fail-on-warnings"
		]
	},
	"graphql": {
		"schema": "https://localhost:3000/graphql",
		"documents": "**/*.{graphql,js,ts,jsx,tsx,svelte}"
	},
	"peerDependencies": {
		"@nais/ds-svelte-community": "^2.0.0-next.8",
		"@navikt/ds-css": "8.9.1",
		"@navikt/ds-tokens": "8.9.1"
	}
}
