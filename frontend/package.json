{
	"name": "console-frontend",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"prepare": "husky && svelte-kit sync || echo ''",
		"dev": "vite dev",
		"dev-live-share": "vite dev --host ::",
		"build": "vite build",
		"preview": "vite preview",
		"check": "pnpm dlx houdini generate && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"eslint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint-staged": "lint-staged",
		"unused": "node find-unused-gql.mjs && echo '---' && node find-missing-css-vars.mjs"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.2",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@layerstack/utils": "2.0.0-next.18",
		"@nais/ds-svelte-community": "2.0.0-next.8",
		"@navikt/ds-css": "8.9.1",
		"@navikt/ds-tokens": "8.9.1",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-themes": "^10.3.5",
		"@storybook/sveltekit": "^10.3.5",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/dom": "^10.4.1",
		"@types/d3-array": "^3.2.2",
		"@types/d3-time": "^3.0.4",
		"@types/luxon": "^3.7.1",
		"@types/react": "^19.2.14",
		"@types/sortablejs": "^1.15.9",
		"date-fns": "^4.1.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "10.3.5",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"houdini": "2.0.0-next.11",
		"houdini-svelte": "3.0.0-next.13",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.5",
		"svelte": "5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.2",
		"vite": "7.3.1",
		"vitest": "^4.1.4"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.0",
		"@slack/types": "^2.20.1",
		"@slack/web-api": "^7.15.1",
		"@types/papaparse": "^5.5.2",
		"cron-parser": "^5.5.0",
		"cronstrue": "^3.14.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"graphql": "^16.13.2",
		"graphql-sse": "^2.6.0",
		"luxon": "^3.7.2",
		"papaparse": "^5.5.3",
		"pino": "^10.3.1",
		"pretty-bytes": "^7.1.0",
		"sortablejs": "^1.15.7",
		"svelte-highlight": "^7.9.0"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.0"
		}
	},
	"lint-staged": {
		"*.{js,ts,svelte,gql,css,md,json}": "prettier --write .",
		"*.{js,ts,svelte,gql}": [
			"eslint --fix .",
			"svelte-check --tsconfig ./tsconfig.json --fail-on-warnings"
		]
	},
	"graphql": {
		"schema": "https://localhost:3000/graphql",
		"documents": "**/*.{graphql,js,ts,jsx,tsx,svelte}"
	},
	"peerDependencies": {
		"@nais/ds-svelte-community": "^2.0.0-next.8",
		"@navikt/ds-css": "8.9.1",
		"@navikt/ds-tokens": "8.9.1",
		"@testing-library/dom": "^10.4.1",
		"@types/react": "^19.2.7"
	}
}
