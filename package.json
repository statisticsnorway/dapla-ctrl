    "body-parser": "^2.2.2",
    "dotenv": "^17.3.1",
    "effect": "^3.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "5.2.1",
    "express-http-proxy": "^2.1.2",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
